#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    show_song_table_header: true,
    draw_borders: true,
    format_tag_separator: " | ",
    browser_column_widths: [20, 38, 42],
    background_color: "#1e1e2e",        // Base
    text_color: "#cdd6f4",              // Text
    header_background_color: "#1e1e2e", // Base
    modal_background_color: "#1e1e2e",  // Base
    modal_backdrop: false,
    preview_label_style: (fg: "#f9e2af"),                // Yellow
    preview_metadata_group_style: (fg: "#f9e2af", modifiers: "Bold"), // Yellow Bold
    tab_bar: (
        active_style: (fg: "#cdd6f4", bg: "#1e1e2e", modifiers: "Bold"),   // Text, Base
        inactive_style: (fg: "#585b70", bg: "#1e1e2e"),                    // Surface2, Base
    ),
    highlighted_item_style: (fg: "#94e2d5", modifiers: "Bold"), // Teal
    current_item_style: (fg: "#cdd6f4", bg: "#313244", modifiers: "Bold"), // Text, Surface0
    borders_style: (fg: "#313244"),                             // Surface0
    highlight_border_style: (fg: "#94e2d5"),                    // Teal
    symbols: (
        song: "S",
        dir: "D",
        playlist: "P",
        marker: "M",
        ellipsis: "...",
        song_style: None,
        dir_style: None,
        playlist_style: None,
    ),
    level_styles: (
        info: (fg: "#89b4fa", bg: "#1e1e2e"),  // Blue
        warn: (fg: "#f9e2af", bg: "#1e1e2e"),  // Yellow
        error: (fg: "#f38ba8", bg: "#1e1e2e"), // Red
        debug: (fg: "#a6e3a1", bg: "#1e1e2e"), // Green
        trace: (fg: "#f5c2e7", bg: "#1e1e2e"), // Pink
    ),
    progress_bar: (
        symbols: ["[", "-", ">", " ", "]"],
        track_style: (fg: "#313244"),        // Surface0
        elapsed_style: (fg: "#94e2d5"),      // Teal
        thumb_style: (fg: "#f5c2e7", bg: "#313244"), // Pink, Surface0
        use_track_when_empty: false,
    ),
    scrollbar: (
        symbols: ["│", "█", "▲", "▼"],
        track_style: (fg: "#313244"),        // Surface0
        ends_style: (fg: "#7f849c"),         // Overlay1
        thumb_style: (fg: "#94e2d5"),        // Teal
    ),
    song_table_format: [
        (
            prop: (kind: Property(Artist),
                default: (kind: Text("Unknown"))
            ),
            width: "20%",
        ),
        (
            prop: (kind: Property(Title),
                default: (kind: Text("Unknown"))
            ),
            width: "35%",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "#a6adc8")), // Subtext0
            default: (kind: Text("Unknown Album"), style: (fg: "#a6adc8")),
            width: "30%",
        ),
        (
            prop: (kind: Property(Duration),
                default: (kind: Text("-"))
            ),
            width: "15%",
            alignment: Right,
        ),
    ],
    components: {},
    layout: Split(
        direction: Vertical,
        panes: [
            (
                pane: Pane(Header),
                size: "2",
            ),
            (
                pane: Pane(Tabs),
                size: "3",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                pane: Pane(ProgressBar),
                size: "1",
            ),
        ],
    ),
    header: (
        rows: [
            (
                left: [
                    (kind: Text("["), style: (fg: "#f9e2af", modifiers: "Bold")),      // Yellow
                    (kind: Property(Status(StateV2(playing_label: "▶ Playing", paused_label: "⏸ Paused", stopped_label: "⏹ Stopped"))), style: (fg: "#f9e2af", modifiers: "Bold")),
                    (kind: Text("]"), style: (fg: "#f9e2af", modifiers: "Bold")),
                ],
                center: [
                    (kind: Property(Song(Title)), style: (fg: "#cdd6f4", modifiers: "Bold"), // Text
                        default: (kind: Text("No Song"), style: (fg: "#cdd6f4", modifiers: "Bold")))
                ],
                right: [
                    (kind: Property(Widget(ScanStatus)), style: (fg: "#94e2d5")), // Teal
                    (kind: Property(Widget(Volume)), style: (fg: "#94e2d5")),     // Teal
                ]
            ),
            (
                left: [
                    (kind: Property(Status(Elapsed))),
                    (kind: Text(" / ")),
                    (kind: Property(Status(Duration))),
                    (kind: Text(" (")),
                    (kind: Property(Status(Bitrate))),
                    (kind: Text(" kbps)"))
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#a6e3a1", modifiers: "Bold"), // Green
                        default: (kind: Text("Unknown"), style: (fg: "#a6e3a1", modifiers: "Bold"))
                    ),
                    (kind: Text(" - ")),
                    (kind: Property(Song(Album)),
                        default: (kind: Text("Unknown Album"))
                    )
                ],
                right: [
                    (
                        kind: Property(Widget(States(
                            active_style: (fg: "#cdd6f4", modifiers: "Bold"), // Text
                            separator_style: (fg: "#6c7086")))                 // Overlay0
                        ),
                        style: (fg: "#6c7086")                                // Overlay0
                    ),
                ]
            ),
        ],
    ),
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track)),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Artist)),
                (kind: Text(" - ")),
                (kind: Property(Title)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    lyrics: (
        timestamp: false
    ),

    cava: (
        // Catppuccin Mocha gradient
        bar_symbols: ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'],
        inverted_bar_symbols: ['▔', '🮂', '🮃', '▀', '🮄', '🮅', '🮆', '█'],
        orientation: Bottom,
        bar_width: 2,
        bar_color: Gradient({
              0: "#313244",  // Surface0
             10: "#94e2d5",  // Teal
             25: "#a6e3a1",  // Green
             50: "#f5c2e7",  // Pink
             75: "#f38ba8",  // Red
        })
    ),
)
